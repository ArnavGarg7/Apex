# .env.example
# Copy to .env and fill in all values

# ── Firebase ───────────────────────────────────────────────────────────────────
# OPTION A: Path to downloaded serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# OPTION B: Entire JSON as a string (for CI/CD environments)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project",...}

# ── OpenWeatherMap ────────────────────────────────────────────────────────────
# Free tier supports 60 calls/min — sufficient for APEX
# Get key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
FF1_CACHE_PATH=./data/ff1_cache
