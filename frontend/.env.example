# VITE Frontend Environment Variables
# All VITE_ vars are exposed to the client bundle

# ── Firebase Web SDK (NOT the service account — these are safe in client) ───
# Get from Firebase Console → Project Settings → Your Apps → Web App
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ── API ──────────────────────────────────────────────────────────────────────
# Points to backend FastAPI server
VITE_API_BASE_URL=http://localhost:8000
